{
  "name": "ffc-doc-statement-generator",
  "version": "2.5.75",
  "description": "FFC payment statement generator",
  "homepage": "https://github.com/DEFRA/ffc-doc-statement-generator",
  "main": "app/index.js",
  "scripts": {
    "pretest": "npm run test:lint",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --coverage=false --onlyChanged --watch --runInBand",
    "test:lint": "eslint",
    "test:lint:fix": "eslint --fix",
    "test:debug": "node --inspect-brk=0.0.0.0 ./node_modules/jest/bin/jest.js --coverage=false --onlyChanged --watch --runInBand --no-cache",
    "start:watch": "nodemon --inspect=0.0.0.0 --ext js --legacy-watch app/index.js",
    "start:debug": "nodemon --inspect-brk=0.0.0.0 --ext js --legacy-watch app/index.js",
    "prepare": "node --eval \"const fs=require('fs'),cp=require('child_process');if(fs.existsSync('.git')&&!process.env.CI&&!process.env.TF_BUILD)cp.execSync('husky',{stdio:'inherit'})\""
  },
  "author": "Defra",
  "contributors": [
    "Callum Leighton callum.leighton@kainos.com",
    "John Watson john.watson2@rpa.gov.uk",
    "Simon Dunn simon.dunn1@defra.gov.uk",
    "Marc Templeton m.templeton@kainos.com",
    "Abidemi Adio abidemi.adio@defra.gov.uk",
    "Leigh Godson leigh.godson@atos.net",
    "Amirs Ishmuhametovs amirs.ishmuhametovs@defra.gov.uk",
    "Sam Plackett samuel.plackett@atos.net",
    "Oliver Lewington oliver.lewington@atos.net"
  ],
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@azure/identity": "4.4.1",
    "@azure/monitor-opentelemetry": "1.16.0",
    "@azure/storage-blob": "12.29.1",
    "@hapi/hapi": "^21.4.8",
    "ffc-alerting-utils": "1.0.9",
    "ffc-database": "1.0.24",
    "ffc-messaging": "2.10.5",
    "ffc-pay-event-publisher": "1.2.3",
    "joi": "17.6.0",
    "log-timestamp": "0.3.0",
    "moment": "2.29.4",
    "pdfmake": "0.2.7",
    "sequelize": "6.37.8"
  },
  "devDependencies": {
    "eslint": "9.39.1",
    "husky": "9.1.7",
    "jest": "29.6.4",
    "jest-junit": "14.0.0",
    "neostandard": "0.12.2",
    "nodemon": "3.0.1"
  },
  "nodemonConfig": {
    "ignore": [
      "**/test-output/**"
    ]
  }
}
